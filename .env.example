# Public values used by the browser-safe Supabase client.
# Run `npm run supabase:status` after starting Supabase to get local values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-or-hosted-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only values. Required only for the scheduled notification route.
# Never prefix these with NEXT_PUBLIC_ and never expose them to browser code.
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key
CRON_SECRET=replace-with-a-long-random-cron-secret
